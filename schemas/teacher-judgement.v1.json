{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "teacher-judgement.v1",
  "type": "object",
  "required": [
    "packet_id",
    "severity",
    "customer_impact",
    "scope",
    "novelty",
    "urgency",
    "confidence",
    "recommended_action",
    "evidence"
  ],
  "properties": {
    "packet_id": {"type": "string"},
    "severity": {"type": "integer", "minimum": 1, "maximum": 4},
    "customer_impact": {"type": "integer", "minimum": 1, "maximum": 4},
    "scope": {"type": "integer", "minimum": 1, "maximum": 4},
    "novelty": {"type": "integer", "minimum": 1, "maximum": 4},
    "urgency": {"type": "integer", "minimum": 1, "maximum": 4},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "recommended_action": {
      "type": "string",
      "enum": [
        "observe",
        "create_ticket",
        "page_owner",
        "page_owner_and_escalate",
        "send_to_human_review"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
